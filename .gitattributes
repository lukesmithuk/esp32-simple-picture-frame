# Normalize line endings. Store every text file as LF in the repository and
# check it out as LF on all platforms (including Windows). This keeps shell
# scripts, Dockerfiles, and CI configs — which run on Linux (the Pi, CI
# runners, the container) — from acquiring CRLF and breaking.
* text=auto eol=lf

# Files that MUST stay LF because they are executed on Linux.
*.sh        text eol=lf
*.py        text eol=lf
*.c         text eol=lf
*.h         text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.md        text eol=lf
Dockerfile  text eol=lf
.dockerignore text eol=lf
.gitignore  text eol=lf
.env.example text eol=lf

# Binary files — never normalize or diff as text.
*.pdf       binary
*.jpg       binary
*.jpeg      binary
*.png       binary
*.webp      binary
*.gif       binary
*.ico       binary
*.bin       binary
*.zip       binary
*.gz        binary
*.tar       binary
