menu "Picture Frame"

    config TEST_MODE
        bool "Enable hardware test mode"
        default n
        help
            When enabled, app_main() runs the hardware integration test suite
            instead of the normal display update cycle.

    config DISABLE_DEEP_SLEEP
        bool "Disable deep sleep (development)"
        default y
        help
            When enabled, the board halts after displaying instead of entering
            deep sleep. Keeps USB-JTAG serial alive for reflashing and debugging.
            Disable for production use.

endmenu
